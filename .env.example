# Copy to .env and fill in your keys. .env is gitignored — never commit it.

# Duffel flights — https://duffel.com (Developer > Test mode access token).
# Test tokens start with "duffel_test_" and have an unlimited sandbox balance.
DUFFEL_API_KEY=

# OpenWeather — https://openweathermap.org/api (free tier).
# Newly created keys can take a couple of hours to activate.
OPENWEATHER_API_KEY=

# Foursquare Places — https://docs.foursquare.com (Service API Key, used as a Bearer token).
FOURSQUARE_API_KEY=

# Anthropic — https://console.anthropic.com (alternative LLM, Claude Sonnet 4.6).
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey (powers the CrewAI agent).
GEMINI_API_KEY=
